generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@map("accounts")
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@map("sessions")
}
 
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  phone         String?
  isAdmin       Boolean   @default(false) @map("is_admin")
  verifiedTier  String    @default("none") @map("verified_tier") // none, tier1, tier2
  createdAt     DateTime  @default(now()) @map("created_at")
  accounts      Account[]
  sessions      Session[]

  storefront    Storefront?
  reviews       Review[]

  @@map("users")
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Storefront {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  slug            String   @unique
  description     String?
  logoUrl         String?
  bannerUrl       String?
  whatsappNumber  String?
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  address         String?
  location        String?
  hours           String[]  @default([])
  tags            String[]  @default([])
  deals           String[]  @default([])
  rating          Decimal   @default(0) @db.Decimal(2, 1)
  reviewsCount    Int       @default(0) @map("reviews_count")
  verifiedTier    String    @default("tier1") @map("verified_tier") // tier1, tier2
  isFeatured      Boolean   @default(false) @map("is_featured")
  boostStatus     String?   @map("boost_status")
  createdAt       DateTime  @default(now()) @map("created_at")

  products        Product[]
  reviews         Review[]
  subscriptions   Subscription[]
  transactions    Transaction[]

  @@map("storefronts")
}

model Product {
  id            String      @id @default(cuid())
  storefrontId  String
  storefront    Storefront  @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  price         Decimal     @db.Decimal(10, 2)
  priceLabel    String?     @map("price_label") // "From TT$120" display text
  imageUrl      String?     @map("image_url")
  tags          String[]    @default([])
  paymentType   String      @default("fygaro") @map("payment_type") // fygaro, deposit, whatsapp_quote
  isFeatured    Boolean     @default(false) @map("is_featured")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("products")
}

model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  storefronts Storefront[]

  @@map("categories")
}

model Review {
  id            String      @id @default(cuid())
  storefrontId  String
  storefront    Storefront  @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  rating        Int
  comment       String?
  status        String      @default("pending")
  createdAt     DateTime    @default(now())

  @@map("reviews")
}

model Subscription {
  id                 String     @id @default(cuid())
  storefrontId       String
  storefront         Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  planName           String
  status             String
  currentPeriodEnd   DateTime

  @@map("subscriptions")
}

model Transaction {
  id            String     @id @default(cuid())
  storefrontId  String
  storefront    Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  amount        Decimal    @db.Decimal(10, 2)
  type          String     // 'subscription', 'boost'
  status        String     // 'pending', 'completed'
  createdAt     DateTime   @default(now())

  @@map("transactions")
}

enum MerchantQueueStatus {
  new_lead
  awaiting_review
  awaiting_customer_info
  ready_to_publish
  published
  rejected
}

enum MerchantOnboardingStatus {
  submitted
  reviewing
  approved
  rejected
  published
}

enum MerchantPaymentStatus {
  pending
  paid
  failed
  refunded
}

model MerchantLead {
  id               String                   @id
  userId           String?                  @map("user_id")
  businessName     String                   @map("business_name")
  category         String?
  email            String
  phone            String?
  whatsappNumber   String?                  @map("whatsapp_number")
  selectedServices Json                     @map("selected_services")
  selectedPlan     String                   @default("starter") @map("selected_plan")
  queueStatus      MerchantQueueStatus      @default(new_lead) @map("queue_status")
  onboardingStatus MerchantOnboardingStatus @default(submitted) @map("onboarding_status")
  paymentStatus    MerchantPaymentStatus    @default(pending) @map("payment_status")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  intakeForms    MerchantIntakeForm[]
  mediaUploads   MerchantMediaUpload[]
  subscriptions  MerchantSubscription[]
  notes          MerchantNote[]
  queueHistory   MerchantQueueHistory[]

  @@map("merchant_leads")
}

model MerchantIntakeForm {
  id                     String   @id
  leadId                 String   @map("lead_id")
  businessCategory       String?  @map("business_category")
  businessDescription    String?  @map("business_description")
  address                String?
  serviceArea            String?  @map("service_area")
  openingHours           String?  @map("opening_hours")
  deliveryAvailable      Boolean  @default(false) @map("delivery_available")
  pickupAvailable        Boolean  @default(true) @map("pickup_available")
  instagram              String?
  facebook               String?
  website                String?
  preferredContactMethod String?  @map("preferred_contact_method")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  lead MerchantLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("merchant_intake_forms")
}

model MerchantMediaUpload {
  id           String   @id
  leadId       String   @map("lead_id")
  fileName     String   @map("file_name")
  fileType     String   @map("file_type")
  fileSize     Int      @map("file_size")
  assetUrl     String   @map("asset_url")
  thumbnailUrl String?  @map("thumbnail_url")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  lead MerchantLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("merchant_media_uploads")
}

model MerchantSubscription {
  id            String   @id
  leadId        String   @map("lead_id")
  selectedPlan  String   @map("selected_plan")
  status        String
  paymentStatus String   @default("pending") @map("payment_status")
  startsAt      DateTime? @map("starts_at")
  endsAt        DateTime? @map("ends_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lead MerchantLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("merchant_subscriptions")
}

model MerchantNote {
  id          String   @id
  leadId      String   @map("lead_id")
  adminUserId String?  @map("admin_user_id")
  note        String
  createdAt   DateTime @default(now()) @map("created_at")

  lead MerchantLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("merchant_notes")
}

model MerchantQueueHistory {
  id         String   @id
  leadId     String   @map("lead_id")
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  actionType String   @map("action_type")
  actionBy   String?  @map("action_by")
  payload    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  lead MerchantLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("merchant_queue_history")
}
